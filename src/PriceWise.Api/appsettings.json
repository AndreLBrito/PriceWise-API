{
  "AllowedHosts": "*",
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=pricewise;Username=pricewise;Password=pricewise"
  },
  "Jwt": {
    "Issuer": "PriceWise",
    "Audience": "PriceWise",
    "Secret": "pricewise-development-secret-key",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "PriceCheck": {
    "Enabled": true,
    "IntervalInMinutes": 30,
    "MaxProductsPerExecution": 50
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "localhost:6379",
    "DefaultExpirationInMinutes": 10
  },
  "Telemetry": {
    "Enabled": true,
    "ServiceName": "PriceWise.Api",
    "ServiceVersion": "1.0.0",
    "Exporter": "Console",
    "EnableMetrics": true,
    "EnableTracing": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }
}
