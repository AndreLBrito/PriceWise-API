{
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=pricewise;Username=pricewise;Password=pricewise"
  },
  "Jwt": {
    "Issuer": "PriceWise",
    "Audience": "PriceWise",
    "Secret": "change-me-local-development-secret-with-at-least-32-characters",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "localhost:6379",
    "DefaultExpirationInMinutes": 10
  },
  "Telemetry": {
    "Enabled": true,
    "ServiceName": "PriceWise.Api",
    "ServiceVersion": "1.0.0",
    "Exporter": "Console",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableMetrics": true,
    "EnableTracing": true
  },
  "Outbox": {
    "Enabled": true,
    "IntervalInSeconds": 30,
    "MaxRetries": 5,
    "BatchSize": 20
  },
  "PriceCheck": {
    "Enabled": true,
    "IntervalInMinutes": 30,
    "MaxProductsPerExecution": 50
  },
  "PriceProvider": {
    "MinimumBasePrice": 50,
    "MaximumBasePrice": 1500,
    "VariationPercentage": 0.03
  },
  "DataSeed": {
    "Enabled": true,
    "CreateDemoUser": true,
    "DemoUserEmail": "demo@pricewise.com",
    "DemoUserPassword": "Demo@123456",
    "CreateDemoData": true
  },
  "AdminSeed": {
    "Enabled": true,
    "Email": "admin@pricewise.com",
    "Password": "Admin@123456"
  },
  "WebhookNotifications": {
    "Enabled": true,
    "TimeoutInSeconds": 10,
    "MaxRetryAttempts": 3
  },
  "EmailNotifications": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 1025,
    "UseSsl": false,
    "UserName": "",
    "Password": "",
    "FromName": "PriceWise",
    "FromEmail": "noreply@pricewise.local",
    "TimeoutInSeconds": 10,
    "MaxRetryAttempts": 3
  }
}
