{
  "AllowedHosts": "*",
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=pricewise;Username=pricewise;Password=pricewise"
  },
  "Jwt": {
    "Issuer": "PriceWise",
    "Audience": "PriceWise",
    "Secret": "pricewise-development-secret-key",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "AuthenticationSecurity": {
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15
  },
  "AdminSeed": {
    "Enabled": true,
    "Email": "admin@pricewise.com",
    "Password": "Admin@123456"
  },
  "PriceCheck": {
    "Enabled": true,
    "IntervalInMinutes": 30,
    "MaxProductsPerExecution": 50
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "localhost:6379",
    "DefaultExpirationInMinutes": 10
  },
  "Telemetry": {
    "Enabled": true,
    "ServiceName": "PriceWise.Api",
    "ServiceVersion": "1.0.0",
    "Exporter": "Console",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableMetrics": true,
    "EnableTracing": true
  },
  "RateLimiting": {
    "Enabled": true,
    "LoginPermitLimit": 5,
    "LoginWindowInMinutes": 1,
    "RefreshTokenPermitLimit": 10,
    "RefreshTokenWindowInMinutes": 1,
    "GeneralPermitLimit": 100,
    "GeneralWindowInMinutes": 1,
    "PriceCheckPermitLimit": 3,
    "PriceCheckWindowInMinutes": 5
  },
  "DataSeed": {
    "Enabled": true,
    "CreateDemoUser": true,
    "DemoUserEmail": "demo@pricewise.com",
    "DemoUserPassword": "Demo@123456",
    "CreateDemoData": true
  },
  "WebhookNotifications": {
    "Enabled": true,
    "TimeoutInSeconds": 10,
    "MaxRetryAttempts": 3
  },
  "EmailNotifications": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 1025,
    "UseSsl": false,
    "UserName": "",
    "Password": "",
    "FromName": "PriceWise",
    "FromEmail": "noreply@pricewise.local",
    "TimeoutInSeconds": 10,
    "MaxRetryAttempts": 3
  },
  "CsvExport": {
    "MaxRows": 10000,
    "DateFormat": "yyyy-MM-dd HH:mm:ss"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }
}
