meta {
  name: Create Price Alert
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/price-alerts
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "productId": "{{productId}}",
    "targetPrice": 1200.00
  }
}

script:post-response {
  const body = res.getBody();
  const data = body && body.data ? body.data : body;
  if (data && data.id) {
    bru.setEnvVar("priceAlertId", data.id);
  }
}
