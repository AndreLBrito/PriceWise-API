ASPNETCORE_ENVIRONMENT=Development
API_PORT=8080

POSTGRES_DB=pricewise
POSTGRES_USER=pricewise
POSTGRES_PASSWORD=change-me-local-postgres
POSTGRES_PORT=5432

REDIS_ENABLED=true
REDIS_PORT=6379

JWT_ISSUER=PriceWise
JWT_AUDIENCE=PriceWise
JWT_SECRET=change-me-local-development-secret-with-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

AUTHENTICATION_SECURITY_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTHENTICATION_SECURITY_LOCKOUT_MINUTES=15

ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@pricewise.com
ADMIN_SEED_PASSWORD=Admin@123456

TELEMETRY_ENABLED=true
TELEMETRY_SERVICE_NAME=PriceWise.Api
TELEMETRY_SERVICE_VERSION=1.0.0
TELEMETRY_EXPORTER=OTLP
TELEMETRY_OTLP_ENDPOINT=http://jaeger:4317
TELEMETRY_ENABLE_METRICS=true
TELEMETRY_ENABLE_TRACING=true

PRICE_CHECK_ENABLED=true
PRICE_CHECK_INTERVAL_IN_MINUTES=30
PRICE_CHECK_MAX_PRODUCTS_PER_EXECUTION=50

RATE_LIMITING_ENABLED=true

DATA_SEED_ENABLED=true
DATA_SEED_CREATE_DEMO_USER=true
DATA_SEED_DEMO_USER_EMAIL=demo@pricewise.com
DATA_SEED_DEMO_USER_PASSWORD=Demo@123456
DATA_SEED_CREATE_DEMO_DATA=true

WEBHOOK_NOTIFICATIONS_ENABLED=true
WEBHOOK_NOTIFICATIONS_TIMEOUT_IN_SECONDS=10
WEBHOOK_NOTIFICATIONS_MAX_RETRY_ATTEMPTS=3

EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_NOTIFICATIONS_HOST=mailpit
EMAIL_NOTIFICATIONS_PORT=1025
EMAIL_NOTIFICATIONS_USE_SSL=false
EMAIL_NOTIFICATIONS_USERNAME=
EMAIL_NOTIFICATIONS_PASSWORD=
EMAIL_NOTIFICATIONS_FROM_NAME=PriceWise
EMAIL_NOTIFICATIONS_FROM_EMAIL=noreply@pricewise.local
EMAIL_NOTIFICATIONS_TIMEOUT_IN_SECONDS=10
EMAIL_NOTIFICATIONS_MAX_RETRY_ATTEMPTS=3

JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

CSV_EXPORT_MAX_ROWS=10000
CSV_EXPORT_DATE_FORMAT="yyyy-MM-dd HH:mm:ss"
